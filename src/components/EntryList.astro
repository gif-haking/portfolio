---
import { ArrowUpRight } from '@lucide/astro';

// src/components/EntryList.astro
interface Entry {
  year: string;
  title: string;
  subtitle?: string;
  href?: string;
}

interface Props {
  entries: Entry[];
}

const { entries } = Astro.props;
---

<div class="entry-list">
  <div class="entry-rows leading-none ">
{entries.map(entry => (
  entry.href ? (
    <a 
      href={entry.href}
      class="entry-row entry-row--linked"
      target={entry.href.startsWith('http') ? '_blank' : '_self'}
      rel={entry.href.startsWith('http') ? 'noopener' : ''}
    >
      <div class="entry-info">
        <span class="entry-title">{entry.title}</span>
        <span class="entry-subtitle">{entry.subtitle}</span>
      </div>
      <span class="entry-year tabular-nums">{entry.year}</span>
    </a>
  ) : (
    <div class="entry-row">
      <div class="entry-info">
        <span class="entry-title">{entry.title}</span>
        <span class="entry-subtitle">{entry.subtitle}</span>
      </div>
      <span class="entry-year tabular-nums">{entry.year}</span>
    </div>
  )
))}
  </div>
</div>

<style>
  .entry-list {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    border-top: 1px solid var(--color-border);
  }

  .entry-rows {
    display: flex;
    flex-direction: column;
  }

  .entry-row {
    display: grid;
    align-items: center;
    color: var(--color-text);
    grid-template-columns: 1fr auto;
    padding-block: 1rem;
    border-bottom: 1px solid var(--color-border);
    transition: color 0.15s ease;
  }

.entry-row--linked:hover .entry-title {
  text-decoration: underline;
  text-underline-offset: 0.2em;
  text-decoration-color: var(--color-text);
}

.entry-row:has(.entry-title--linked) {
  cursor: pointer;
}


  .entry-title:not(.entry-title--linked) {
  pointer-events: none;
  cursor: default;
}


  .entry-info {
    display: flex;
    flex-direction: row;
    gap: 0.5rem;
    align-items: center; 
  }

  .entry-title {
    font-weight: var(--font-weight-medium);

  }

  .entry-subtitle {
    color: var(--color-text-muted);
  }

    .entry-year {
    color: var(--color-text-muted);
  }

</style>