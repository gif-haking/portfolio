---
import { ArrowUpRight } from '@lucide/astro';

// src/components/EntryList.astro
interface Entry {
  year: string;
  title: string;
  subtitle?: string;
  href?: string;
}

interface Props {
  entries: Entry[];
}

const { entries } = Astro.props;
---

<div class="entry-list">
  <div class="entry-rows leading-none ">
{entries.map(entry => (
  entry.href 
    ? (
      <a 
        href={entry.href}
        class="entry-row entry-row--linked"
        target={entry.href.startsWith('http') ? '_blank' : '_self'}
        rel={entry.href.startsWith('http') ? 'noopener' : ''}
      >
        <span class="entry-year tabular-numbers">{entry.year}</span>
        <div class="entry-info">
          <span class="entry-title mb-1">{entry.title}</span>
          <span class="entry-subtitle">{entry.subtitle}</span>
        </div>
<span class="entry-arrow">
  {entry.href && <ArrowUpRight size={16} strokeWidth={1} />}
</span>   
</a>
    ) : (
  <div class="entry-row">
    <span class="entry-year tabular-numbers">{entry.year}</span>
    <div class="entry-info">
      <span class="entry-title mb-1">{entry.title}</span>
      <span class="entry-subtitle">{entry.subtitle}</span>
    </div>
    <span class="entry-arrow"></span>
  </div>
)
))}
  </div>
</div>

<style>
  .entry-list {
    display: grid;
    grid-template-columns: 1fr;
    align-items: top;
    border-top: 1px solid var(--color-border);
  }

  .entry-rows {
    display: flex;
    flex-direction: column;
  }

  .entry-row {
    display: grid;
    align-items: start;
    color: var(--color-text);
    grid-template-columns: 1fr 2fr auto;
    padding-block: 1rem;
    border-bottom: 1px solid var(--color-border);
    transition: color 0.15s ease;
  }

  .entry-row--linked:hover {
    color: var(--color-text-muted);
  }

  .entry-row:not(.entry-row--linked) {
  pointer-events: none;
  cursor: default;
}


  .entry-info {
    display: flex;
    flex-direction: column;
  }

  .entry-title {
    font-weight: var(--font-weight-medium);

  }

  .entry-subtitle {
    color: var(--color-text-muted);
  }

.entry-arrow {
  width: 1rem;
}
</style>