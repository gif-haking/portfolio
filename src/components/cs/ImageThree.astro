---
interface Props {
  caption?: string;
  background?: string;
}

const { caption, background } = Astro.props;
---

<figure class="cs-image-three" style={background ? `background:${background}` : ''}>
  <div class="cs-image-three-grid">
    <slot />
  </div>
  {caption && <figcaption class="cs-caption">{caption}</figcaption>}
</figure>

<style>
  .cs-image-three {
    width: 100%;
    margin: 3rem 0;
    padding: 3rem;
    border-radius: 8px;
    background: var(--color-surface);
  }

  .cs-image-three-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
  }

  .cs-image-three-grid :global(img) {
    width: 100%;
    height: auto;
    border-radius: 4px;
  }

  .cs-caption {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: 0.75rem;
    text-align: center;
  }
</style>
