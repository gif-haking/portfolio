---
interface Props {
  heading?: string;
}

const { heading } = Astro.props;
---

<section class="cs-container">
  {heading && <h2 class="cs-intro-heading">{heading}</h2>}
  <div class="cs-intro-body"><slot /></div>
</section>

<style>
  .cs-intro-heading {
    font-size: 0.75rem;
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .cs-intro-body {
    max-width: 66%;
    font-size: 1.125rem;
    line-height: var(--leading-relaxed);
    color: var(--color-text-body);
  }
</style>

