---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  role: string;
  status: string;
  company?: string;
  coverColor?: string;
}

const { title, description, role, status, company, coverColor = '#E8E6DF' } = Astro.props;
---

<BaseLayout title={`${title} — Your Name`} description={description}>
  <article class="case-study">

    <header class="cs-header">
      <div class="container">
        <div class="cs-meta">
        <h1 class="cs-title">{title}</h1>
        <p class="cs-description">{description}</p>
        <div class="cs-details">
          <div class="cs-detail">
            <span class="detail-label">Role</span>
            <span>{role}</span>
            <span>{company}</span>
            <span>{status}</span>
          </div>
        </div>
      </div>
    </header>

    <div class="cs-cover" style={`background-color: ${coverColor};`}></div>

    <div class="cs-body">
      <div class="container cs-content">
        <slot />
      </div>
    </div>

    <footer class="cs-footer">
      <div class="container">
        <a href="/" class="back-link">← Back to work</a>
      </div>
    </footer>

  </article>
</BaseLayout>

<style>
  .container {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .cs-header {
    padding: 5rem 0 3rem;
  }

  .cs-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .cs-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  .cs-description {
    font-size: 1.125rem;
    color: var(--color-muted);
    font-weight: 300;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .cs-details {
    display: flex;
    gap: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .cs-detail {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .detail-label {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
  }

  .cs-detail span:last-child {
    font-size: 0.9375rem;
    font-weight: 300;
  }

  .cs-cover {
    width: 100%;
    aspect-ratio: 21 / 9;
    margin: 3rem 0;
  }

  .cs-body {
    padding-bottom: 6rem;
  }

  .cs-content {
    /* Prose styles for case study content */
  }

  .cs-content :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 3.5rem 0 1rem;
  }

  .cs-content :global(h3) {
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    margin: 2.5rem 0 0.75rem;
  }

  .cs-content :global(p) {
    font-size: 1.0625rem;
    font-weight: 300;
    color: var(--color-text);
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }

  .cs-content :global(ul),
  .cs-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .cs-content :global(li) {
    font-size: 1.0625rem;
    font-weight: 300;
    line-height: 1.7;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .cs-content :global(blockquote) {
    border-left: 2px solid var(--color-border);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-style: italic;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .cs-content :global(.image-block) {
    margin: 3rem 0;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .cs-content :global(.image-block img) {
    width: 100%;
  }

  .cs-content :global(.image-caption) {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-top: 0.75rem;
    text-align: center;
  }

  .cs-content :global(.stat-row) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin: 3rem 0;
  }

  .cs-content :global(.stat) {
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-align: center;
  }

  .cs-content :global(.stat-number) {
    font-family: var(--font-serif);
    font-size: 2.25rem;
    font-weight: 400;
    letter-spacing: -0.03em;
    display: block;
    margin-bottom: 0.35rem;
  }

  .cs-content :global(.stat-label) {
    font-size: 0.8rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .cs-footer {
    padding: 3rem 0 6rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-size: 0.9rem;
    color: var(--color-muted);
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: var(--color-off-black);
  }
</style>
