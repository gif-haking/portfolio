---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Product designer crafting thoughtful digital experiences.' } = Astro.props;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap">  </head>
  <body class="antialiased">

    <!-- Hidden SVG filter definition -->
  <svg width="0" height="0" style="position:absolute">
    <filter id="noise-bg-fx">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.8"
        numOctaves="4"
        stitchTiles="stitch"
      />
    </filter>
  </svg>

  <!-- Noise overlay -->
  <div class="noise"></div>

    <header class="site-header">
      <nav class="nav">
        <a href="/" class="nav-logo">Hayden King</a>
        <ul class="nav-links">
          <li><a href="/" class="nav-link">Work</a></li>
          <li><a href="/about" class="nav-link">About</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} Hayden King</p>
      <div class="footer-links">
        <a href="mailto:hello@yourname.com">Email</a>
        <a href="https://linkedin.com/in/yourname" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://read.cv/yourname" target="_blank" rel="noopener">CV</a>
      </div>
    </footer>

  </body>
</html>

<style>

.noise {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 9999;

  opacity: 0.12;
  mix-blend-mode: multiply;

  filter: url("#noise-bg-fx") grayscale(100%);
}
  .site-header {
    padding: 1.5rem 0;
  }

  .nav {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-size: 1.125rem;
    letter-spacing: -0.01em;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--color-muted);
    transition: color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .site-footer {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 0rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a:hover {
    color: var(--color-text);
  }
</style>